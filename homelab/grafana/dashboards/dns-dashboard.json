{
  "__inputs": [
    {
      "name": "DS_CLICKHOUSE",
      "label": "ClickHouse",
      "description": "",
      "type": "datasource",
      "pluginId": "grafana-clickhouse-datasource",
      "pluginName": "ClickHouse"
    }
  ],
  "__elements": {},
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "grafana-clickhouse-datasource", "name": "ClickHouse", "version": "4.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "piechart", "name": "Pie chart", "version": ""},
    {"type": "panel", "id": "barchart", "name": "Bar chart", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""}
  ],
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Total Queries",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "unit": "short"}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto", "colorMode": "value", "graphMode": "area"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT count() AS value FROM ocsf.dns_activity WHERE $__timeFilter(time)"
        }
      ]
    },
    {
      "id": 2,
      "title": "Unique Clients",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "unit": "short"}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto", "colorMode": "value", "graphMode": "area"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT uniqExact(src_endpoint.ip) AS value FROM ocsf.dns_activity WHERE $__timeFilter(time)"
        }
      ]
    },
    {
      "id": 3,
      "title": "Unique Domains",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "unit": "short"}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto", "colorMode": "value", "graphMode": "area"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT uniqExact(query.hostname) AS value FROM ocsf.dns_activity WHERE $__timeFilter(time)"
        }
      ]
    },
    {
      "id": 4,
      "title": "Avg QPS",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "unit": "short", "decimals": 2}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto", "colorMode": "value", "graphMode": "area"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT round(count() / greatest((toUnixTimestamp(max(time)) - toUnixTimestamp(min(time))), 1), 2) AS value FROM ocsf.dns_activity WHERE $__timeFilter(time)"
        }
      ]
    },
    {
      "id": 5,
      "title": "Queries per Minute",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "showPoints": "never"}, "unit": "short"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": false}, "tooltip": {"mode": "single", "sort": "none"}},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
          "editorType": "sql",
          "queryType": "timeseries",
          "format": 0,
          "rawSql": "SELECT toStartOfMinute(time) AS time, count() AS queries FROM ocsf.dns_activity WHERE $__timeFilter(time) GROUP BY time ORDER BY time"
        }
      ]
    },
    {
      "id": 6,
      "title": "Query Types Over Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "bars", "fillOpacity": 80, "stacking": {"mode": "normal", "group": "A"}}, "unit": "short"}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["sum"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
          "editorType": "sql",
          "queryType": "timeseries",
          "format": 0,
          "rawSql": "SELECT toStartOfMinute(time) AS time, query.type AS qtype, count() AS n FROM ocsf.dns_activity WHERE $__timeFilter(time) GROUP BY time, qtype ORDER BY time"
        }
      ]
    },
    {
      "id": 7,
      "title": "Query Type Distribution",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 12},
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
      "fieldConfig": {"defaults": {"custom": {"hideFrom": {"legend": false, "tooltip": false, "viz": false}}, "unit": "short"}, "overrides": []},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""}, "pieType": "donut", "tooltip": {"mode": "single"}, "legend": {"displayMode": "table", "placement": "right", "values": ["value", "percent"]}, "displayLabels": ["name"]},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT query.type AS qtype, count() AS n FROM ocsf.dns_activity WHERE $__timeFilter(time) GROUP BY qtype ORDER BY n DESC"
        }
      ]
    },
    {
      "id": 8,
      "title": "Top TLDs",
      "type": "barchart",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 12},
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
      "fieldConfig": {"defaults": {"custom": {"axisPlacement": "auto", "fillOpacity": 80, "lineWidth": 1}, "unit": "short"}, "overrides": []},
      "options": {"orientation": "horizontal", "showValue": "auto", "stacking": "none", "legend": {"displayMode": "hidden"}, "tooltip": {"mode": "single"}, "xTickLabelRotation": 0},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT arrayElement(splitByChar('.', query.hostname), -1) AS tld, count() AS n FROM ocsf.dns_activity WHERE $__timeFilter(time) GROUP BY tld ORDER BY n DESC LIMIT 15"
        }
      ]
    },
    {
      "id": 9,
      "title": "Long-Name Domains (potential DGA / tunneling)",
      "type": "table",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 12},
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
      "fieldConfig": {"defaults": {"custom": {"align": "auto", "displayMode": "auto"}}, "overrides": []},
      "options": {"showHeader": true},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT query.hostname AS qname, length(query.hostname) AS len, count() AS n FROM ocsf.dns_activity WHERE $__timeFilter(time) AND length(query.hostname) > 50 GROUP BY qname, len ORDER BY n DESC LIMIT 25"
        }
      ]
    },
    {
      "id": 10,
      "title": "Top Clients",
      "type": "table",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
      "fieldConfig": {"defaults": {"custom": {"align": "auto", "displayMode": "auto"}}, "overrides": []},
      "options": {"showHeader": true},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT src_endpoint.ip AS client, count() AS queries, uniqExact(query.hostname) AS unique_domains, round(count() / uniqExact(query.hostname), 1) AS queries_per_domain FROM ocsf.dns_activity WHERE $__timeFilter(time) GROUP BY client ORDER BY queries DESC LIMIT 25"
        }
      ]
    },
    {
      "id": 11,
      "title": "Top Domains",
      "type": "table",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
      "fieldConfig": {"defaults": {"custom": {"align": "auto", "displayMode": "auto"}}, "overrides": []},
      "options": {"showHeader": true},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT query.hostname AS qname, count() AS n FROM ocsf.dns_activity WHERE $__timeFilter(time) GROUP BY qname ORDER BY n DESC LIMIT 25"
        }
      ]
    },
    {
      "id": 12,
      "title": "Encrypted-DNS Discovery Probes (devices trying to bypass pihole)",
      "type": "table",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 28},
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
      "fieldConfig": {"defaults": {"custom": {"align": "auto", "displayMode": "auto"}}, "overrides": []},
      "options": {"showHeader": true},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT src_endpoint.ip AS client, query.hostname AS qname, count() AS probes FROM ocsf.dns_activity WHERE $__timeFilter(time) AND query.hostname IN ('_dns.resolver.arpa', 'use-application-dns.net', 'mask.icloud.com') GROUP BY client, qname ORDER BY probes DESC"
        }
      ]
    },
    {
      "id": 13,
      "title": "mDNS / Service-Discovery Activity per Client",
      "type": "table",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 28},
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
      "fieldConfig": {"defaults": {"custom": {"align": "auto", "displayMode": "auto"}}, "overrides": []},
      "options": {"showHeader": true},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}"},
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT src_endpoint.ip AS client, countIf(endsWith(query.hostname, '.local')) AS mdns, countIf(startsWith(query.hostname, '_')) AS srv_or_svcb, count() AS total FROM ocsf.dns_activity WHERE $__timeFilter(time) GROUP BY client HAVING mdns + srv_or_svcb > 0 ORDER BY mdns + srv_or_svcb DESC LIMIT 25"
        }
      ]
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["dns", "ocsf", "tenzir"],
  "templating": {"list": []},
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "DNS Activity (OCSF)",
  "uid": "dns-ocsf",
  "version": 1,
  "weekStart": ""
}
